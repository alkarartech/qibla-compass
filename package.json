{
  "name": "qibla-compass",
  "version": "1.0.1",
  "description": "Accurate Qibla bearing and compass utilities for JavaScript/TypeScript (React Native, Expo, web)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "qibla",
    "compass",
    "bearing",
    "kaaba",
    "islamic",
    "prayer",
    "geodesic",
    "vincenty",
    "magnetic-declination"
  ],
  "author": "Alkarar Tech <haydar.alkararllc@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alkarartech/qibla-compass.git"
  },
  "homepage": "https://github.com/alkarartech/qibla-compass#readme",
  "bugs": {
    "url": "https://github.com/alkarartech/qibla-compass/issues"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
